# Data / results (paths point outside the repo on the HPC anyway)
*.gff3
*.fasta
*.faa
*.fa
*.tsv
*.csv
*.txt
*.json
*.bed

# Keep config tables that ARE part of the repo
!config/chromosome_id_map.tsv

# Keep the small bundled reference tables (see reference_data/CITATIONS.md).
# Large reference proteome FASTAs stay ignored - download them per CITATIONS.md.
!reference_data/*.csv
!reference_data/*.txt
!reference_data/*.md

# Figures
*.png
*.pdf

# SLURM logs
*.out
*.err
*.log

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Editor
.vscode/
.idea/
